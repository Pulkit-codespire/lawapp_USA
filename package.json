{
  "name": "lawapp-server",
  "version": "0.1.0",
  "description": "LawApp legal research assistant — Node.js backend with RAG pipeline",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate": "npx sequelize-cli db:migrate",
    "migrate:undo": "npx sequelize-cli db:migrate:undo",
    "migrate:undo:all": "npx sequelize-cli db:migrate:undo:all",
    "seed": "npx sequelize-cli db:seed:all",
    "setup": "node scripts/setupDb.js",
    "ingest": "node scripts/batchIngest.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "async-retry": "^1.3.3",
    "cli-progress": "^3.12.0",
    "commander": "^12.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-validator": "^7.2.0",
    "helmet": "^7.1.0",
    "joi": "^17.13.0",
    "js-tiktoken": "^1.0.14",
    "mammoth": "^1.8.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.67.0",
    "p-limit": "^3.1.0",
    "pdf-parse": "^1.1.1",
    "pdf-to-img": "^5.0.0",
    "pg": "^8.13.0",
    "pg-hstore": "^2.3.4",
    "pgvector": "^0.2.0",
    "sequelize": "^6.37.0",
    "sharp": "^0.33.0",
    "tesseract.js": "^5.1.0",
    "uuid": "^10.0.0",
    "winston": "^3.14.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "nodemon": "^3.1.0",
    "sequelize-cli": "^6.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
