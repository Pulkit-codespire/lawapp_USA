# --- Ingestion Settings ---
CASE_FILES_ROOT=C:/legal_cases
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# --- Embedding Settings ---
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
EMBEDDING_BATCH_SIZE=100

# --- Chat LLM Settings ---
CHAT_MODEL=gpt-4o
CHAT_MAX_TOKENS=2000
