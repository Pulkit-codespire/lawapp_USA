# ===========================
# LawApp Server — Environment Variables
# ===========================
# Copy this file to .env and fill in your values
# cp .env.example .env

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-api-key-here

# --- Database (PostgreSQL with pgvector) ---
DATABASE_URL=postgres://postgres:password@localhost:5432/lawapp

# --- Ingestion Settings ---
CASE_FILES_ROOT=C:/legal_cases
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# --- Embedding Settings ---
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
EMBEDDING_BATCH_SIZE=100

# --- Chat LLM Settings ---
CHAT_MODEL=gpt-4o
CHAT_MAX_TOKENS=2000
CHAT_TEMPERATURE=0.1

# --- RAG Settings ---
TOP_K_RESULTS=10
SIMILARITY_THRESHOLD=0.70
RERANK_TOP_K=5

# --- Server ---
HOST=0.0.0.0
PORT=8000
NODE_ENV=development
